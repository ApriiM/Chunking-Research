# LLM provider for lumberchunker_api: openai | gemini
LUMBERCHUNKER_API_PROVIDER=openai

# Model name passed to provider SDK
# Examples:
# - OpenAI: gpt-4o-mini
# - OpenAI-compatible: your-model-name
# - Gemini: gemini-1.5-pro
LUMBERCHUNKER_API_MODEL=gpt-4o-mini

# Optional for OpenAI-compatible endpoints (leave empty for default OpenAI)
# Example: https://api.openai.com/v1
LUMBERCHUNKER_API_BASE_URL=http://localhost:8000/v1

# API keys (set what you use)
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional: if you use custom env name for api_key in config
# MY_CUSTOM_API_KEY=
